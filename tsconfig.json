{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    "allowJs": true,
    "checkJs": false,
    "noEmit": true,

    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "types": ["vite/client"]
  },
  "include": ["src"]
}